---
export interface Props {
  title: string;
  description: string;
  icon?: string;
  color?: string;
  image?: string;
}
const { title, description, icon, color = "#1e4fa8", image } = Astro.props;
---

<div class="service-card">
  {image && (
    <div class="card-image-wrap">
      <img src={image} alt={title} class="card-image" loading="lazy" />
      <div class="card-image-overlay" style={`background: linear-gradient(135deg, ${color}cc, ${color}88)`}></div>
      <div class="card-icon-overlay" style={`color: white`} set:html={icon}></div>
    </div>
  )}
  {!image && (
    <div class="card-icon" style={`background: ${color}18; color: ${color}`} set:html={icon}></div>
  )}
  <div class="card-body">
    <h3>{title}</h3>
    <p>{description}</p>
    <a href="/services" class="card-link">
      Learn more
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</div>

<style>
.service-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  border: 1px solid var(--gray-100);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.service-card:hover {
  transform: translateY(-6px);
  box-shadow: var(--shadow-lg);
}
.card-image-wrap {
  position: relative;
  height: 180px;
  overflow: hidden;
}
.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.service-card:hover .card-image {
  transform: scale(1.06);
}
.card-image-overlay {
  position: absolute;
  inset: 0;
  opacity: 0.65;
}
.card-icon-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.card-icon-overlay :global(svg) {
  width: 48px;
  height: 48px;
  filter: drop-shadow(0 2px 6px rgba(0,0,0,0.3));
}
.card-body {
  padding: 1.6rem 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
  flex: 1;
}
.card-icon {
  width: 56px; height: 56px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 2rem 1.75rem 0;
}
.card-icon :global(svg) { width: 26px; height: 26px; }
h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--blue-dark);
}
p {
  font-size: 0.88rem;
  color: var(--gray-600);
  line-height: 1.65;
  flex: 1;
}
.card-link {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--blue-mid);
  transition: gap 0.2s, color 0.2s;
  margin-top: 0.25rem;
}
.card-link:hover {
  color: var(--orange);
  gap: 0.6rem;
}
</style>
