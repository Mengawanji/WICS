---
const services = [
  "Documentation Services",
  "CANAL+ Subscription",
  "DStv Subscription",
  "StarTimes",
  "Flight Ticket Sales",
  "AXA Motor Insurance",
  "DHL Express Services",
  "CAMTEL BLUE SIM",
];
---

<footer class="footer">
  <div class="footer-top">
    <div class="container footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="28" height="28" rx="7" fill="#f97316"/>
            <path d="M7 9h14M7 14h10M7 19h12" stroke="white" stroke-width="2.2" stroke-linecap="round"/>
          </svg>
          <span>WICS <span>Agency</span></span>
        </div>
        <p class="footer-tagline">Your trusted partner for fast, reliable services in Limbe, Cameroon. Over 9 years of excellence.</p>
        <div class="footer-social">
          <a href="https://wa.me/237699949035" target="_blank" rel="noopener noreferrer" class="social-btn whatsapp" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
          <a href="tel:+237699949035" class="social-btn phone" aria-label="Call us">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">About Us</a></li>
          <li><a href="/services">Services</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Our Services</h4>
        <ul>
          {services.slice(0,4).map(s => <li><a href="/services">{s}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Contact Info</h4>
        <div class="contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
          <div>
            <a href="tel:+237699949035">699 94 90 35</a><br/>
            <a href="tel:+237651073932">651 07 39 32</a>
          </div>
        </div>
        <div class="contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Mokundange, Limbe<br/>Beside Port Authority</span>
        </div>
        <div class="contact-item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Mon–Sat: 8:00 AM – 6:00 PM</span>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p>&copy; {new Date().getFullYear()} WICS Agency. All rights reserved.</p>
      <p>Mokundange, Limbe, Cameroon</p>
    </div>
  </div>
</footer>

<style>
.footer {
  background: var(--blue-dark);
  color: rgba(255,255,255,0.75);
  font-size: 0.9rem;
}
.footer-top { padding: 4rem 0 3rem; }
.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 2.5rem;
}
.footer-logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--white);
  margin-bottom: 1rem;
}
.footer-logo span span { color: var(--orange); }
.footer-tagline { line-height: 1.7; margin-bottom: 1.5rem; }

.footer-social { display: flex; gap: 0.75rem; }
.social-btn {
  width: 42px; height: 42px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.2s, opacity 0.2s;
}
.social-btn:hover { transform: scale(1.12); opacity: 0.9; }
.social-btn.whatsapp { background: #25D366; color: white; }
.social-btn.whatsapp svg { width: 20px; height: 20px; }
.social-btn.phone { background: var(--blue-mid); color: white; }
.social-btn.phone svg { width: 18px; height: 18px; }

.footer-col h4 {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 1.2rem;
  position: relative;
  padding-bottom: 0.6rem;
}
.footer-col h4::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0;
  width: 28px; height: 2px;
  background: var(--orange);
  border-radius: 2px;
}
.footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
.footer-col ul li a {
  color: rgba(255,255,255,0.68);
  transition: color 0.2s;
  font-size: 0.88rem;
}
.footer-col ul li a:hover { color: var(--orange); }

.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  margin-bottom: 1rem;
  font-size: 0.88rem;
  color: rgba(255,255,255,0.7);
}
.contact-item svg { margin-top: 2px; flex-shrink: 0; }
.contact-item a { color: rgba(255,255,255,0.7); transition: color 0.2s; }
.contact-item a:hover { color: var(--orange); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 1.25rem 0;
}
.footer-bottom .container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}
.footer-bottom p { font-size: 0.82rem; color: rgba(255,255,255,0.45); }

@media (max-width: 900px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 540px) {
  .footer-grid { grid-template-columns: 1fr; }
  .footer-bottom .container { flex-direction: column; text-align: center; }
}
</style>
