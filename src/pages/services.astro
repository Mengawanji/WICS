---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const serviceGroups = [
  {
    group: "Documentation & Administrative",
    color: "#1e4fa8",
    bgColor: "#1e4fa815",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    services: [
      { name: "Documentation Services", desc: "We handle all types of official documents including permits, certificates, attestations, apostilles, and administrative paperwork. Save time and let our experts manage the process from start to finish." }
    ]
  },
  {
    group: "Satellite TV Subscriptions",
    color: "#f97316",
    bgColor: "#f9731615",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>`,
    services: [
      { name: "CANAL+ Subscription", desc: "Subscribe or renew your CANAL+ package quickly and easily. We offer all CANAL+ plans with competitive rates. Same-day activation guaranteed." },
      { name: "DStv Subscription", desc: "All DStv packages available — Compact, Compact Plus, Premium and more. Fast subscription processing with instant activation." },
      { name: "StarTimes Subscription", desc: "Affordable StarTimes packages for all viewing needs. New subscriptions, renewals, and decoder sales available." }
    ]
  },
  {
    group: "Travel & Ticketing",
    color: "#0ea5e9",
    bgColor: "#0ea5e915",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>`,
    services: [
      { name: "Flight Ticket Sales", desc: "Book domestic and international flight tickets through our trusted travel partners. We help you find the best routes and prices for any destination." }
    ]
  },
  {
    group: "Insurance",
    color: "#10b981",
    bgColor: "#10b98115",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    services: [
      { name: "AXA Motor Insurance", desc: "Official AXA Insurance partner for motor vehicle coverage. We offer third-party liability, comprehensive plans, and all standard AXA motor insurance products at competitive rates." }
    ]
  },
  {
    group: "Courier & Shipping",
    color: "#f59e0b",
    bgColor: "#f59e0b15",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
    services: [
      { name: "DHL Express Services", desc: "Send documents and packages locally or internationally through DHL Express. We handle packing guidance, shipment booking, tracking setup, and pickup coordination." }
    ]
  },
  {
    group: "Telecom Services",
    color: "#8b5cf6",
    bgColor: "#8b5cf615",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    services: [
      { name: "CAMTEL BLUE SIM – Sales", desc: "Purchase your CAMTEL BLUE SIM card with all standard plans for calls, SMS and mobile internet. Quick activation with identity verification support." },
      { name: "CAMTEL BLUE SIM – Recharge", desc: "Recharge your CAMTEL BLUE SIM with any amount. Fast, reliable, and no service fees. Available for all CAMTEL data and voice bundles." }
    ]
  }
];
---

<Layout title="Our Services" description="WICS Agency offers documentation, CANAL+, DStv, StarTimes, flight tickets, AXA insurance, DHL, and CAMTEL services in Limbe, Cameroon.">
  <Navbar />

  <!-- HERO -->
  <section class="page-hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1664575602554-2087b04935a5?w=1400&q=80&auto=format"
        alt="Business services"
        class="hero-img"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="breadcrumb"><a href="/">Home</a> / <span>Services</span></div>
      <h1>Our Services</h1>
      <p>Comprehensive solutions for individuals and businesses — all in one place.</p>
    </div>
  </section>

  <!-- INTRO -->
  <section class="services-intro">
    <div class="container">
      <div class="intro-box">
        <div>
          <h2>Everything You Need, Under One Roof</h2>
          <p>At WICS Agency, we have carefully curated a suite of high-demand services to make your life easier. Our team handles each request with speed, professionalism, and attention to detail.</p>
        </div>
        <div class="intro-ctas">
          <a href="tel:+237699949035" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
            Call Now
          </a>
          <a href="https://wa.me/237699949035" class="btn btn-whatsapp" target="_blank" rel="noopener">
            WhatsApp Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE GROUPS -->
  {serviceGroups.map((group, gi) => (
    <section class={`service-group ${gi % 2 === 1 ? 'bg-light' : ''}`}>
      <div class="container">
        <div class="group-header">
          <div class="group-icon" style={`background: ${group.bgColor}; color: ${group.color}`} set:html={group.icon}></div>
          <div>
            <span class="section-label">{group.group}</span>
          </div>
        </div>
        <div class={`group-cards cols-${group.services.length > 1 ? '3' : '1'}`}>
          {group.services.map(s => (
            <div class="detail-card" style={`border-top: 4px solid ${group.color}`}>
              <div class="dc-icon" style={`background: ${group.bgColor}; color: ${group.color}`} set:html={group.icon}></div>
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
              <div class="dc-actions">
                <a href="tel:+237699949035" class="dc-btn" style={`color: ${group.color}`}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
                  Call to Inquire
                </a>
                <a href="https://wa.me/237699949035" class="dc-btn dc-btn-wa">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  WhatsApp
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- PARTNERS STRIP -->
  <section class="partners-section">
    <div class="container">
      <p class="partners-label">Trusted Partners</p>
      <div class="partners-row">
        {[<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 100" width="300" height="100">
  <!-- Black background rectangle -->
  <rect x="0" y="0" width="300" height="100" rx="4" ry="4" fill="#1a1a1a"/>
  <!-- CANAL+ text in white, bold -->
  <text x="150" y="68" font-family="Arial Black, Helvetica Neue, Arial, sans-serif" font-size="58" font-weight="900" fill="white" text-anchor="middle" dominant-baseline="auto" letter-spacing="-1">CANAL+</text>
</svg>,
        
      

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 100" width="320" height="100">
  <!-- AXA square background -->
  <rect x="10" y="15" width="72" height="72" fill="#1a1f8c"/>
  <!-- Red diagonal slash -->
  <line x1="48" y1="18" x2="74" y2="82" stroke="#e8001c" stroke-width="6" stroke-linecap="round"/>
  <!-- AXA text in white -->
  <text x="46" y="68" font-family="Arial Black, Arial, sans-serif" font-size="30" font-weight="900" fill="white" text-anchor="middle" dominant-baseline="auto" letter-spacing="1">AXA</text>
  <!-- Investment Managers text -->
  <text x="100" y="50" font-family="Georgia, Times New Roman, serif" font-size="22" font-weight="400" fill="#1a1f8c" dominant-baseline="middle">Investment</text>
  <text x="100" y="76" font-family="Georgia, Times New Roman, serif" font-size="22" font-weight="400" fill="#1a1f8c" dominant-baseline="middle">Managers</text>
</svg>,


<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 120" width="280" height="120">
  <!-- Main ticket body -->
  <rect x="5" y="5" width="275" height="110" rx="10" ry="10" fill="white" stroke="#e0e0e0" stroke-width="1.5"/>
  <!-- Red header strip -->
  <rect x="5" y="5" width="275" height="38" rx="10" ry="10" fill="#cc1122"/>
  <rect x="5" y="28" width="275" height="15" fill="#cc1122"/>

  <!-- Perforation line -->
  <line x1="218" y1="5" x2="218" y2="115" stroke="#e0e0e0" stroke-width="1.5" stroke-dasharray="5,4"/>

  <!-- Barcode area (left) -->
  <rect x="14" y="50" width="22" height="60" rx="2" fill="#222"/>
  <rect x="18" y="50" width="3" height="60" fill="white"/>
  <rect x="24" y="50" width="2" height="60" fill="white"/>
  <rect x="29" y="50" width="4" height="60" fill="white"/>

  <!-- Header fields: Passenger, Date, Seat, Flight -->
  <text x="48" y="20" font-family="Arial, sans-serif" font-size="7" fill="white" letter-spacing="0.5" font-weight="600">NAME OF PASSENGER</text>
  <text x="48" y="31" font-family="Arial Black, Arial, sans-serif" font-size="10" fill="white" font-weight="900">JEAK BLACK</text>

  <text x="118" y="20" font-family="Arial, sans-serif" font-size="7" fill="white" letter-spacing="0.5" font-weight="600">DATE</text>
  <text x="118" y="31" font-family="Arial Black, Arial, sans-serif" font-size="10" fill="white" font-weight="900">09 NOV 2018</text>

  <text x="173" y="20" font-family="Arial, sans-serif" font-size="7" fill="white" letter-spacing="0.5" font-weight="600">SEAT</text>
  <text x="173" y="31" font-family="Arial Black, Arial, sans-serif" font-size="10" fill="white" font-weight="900">9A</text>

  <text x="193" y="20" font-family="Arial, sans-serif" font-size="7" fill="white" letter-spacing="0.5" font-weight="600">FLIGHT</text>
  <text x="193" y="31" font-family="Arial Black, Arial, sans-serif" font-size="10" fill="white" font-weight="900">AEROFLO AIR</text>

  <!-- Route: New York → London -->
  <text x="50" y="72" font-family="Arial Black, Arial, sans-serif" font-size="18" font-weight="900" fill="#1a1a1a">New York</text>
  <text x="155" y="72" font-family="Arial Black, Arial, sans-serif" font-size="18" font-weight="900" fill="#cc1122">London</text>

  <!-- Airplane icon -->
  <g transform="translate(130,62) scale(0.7)">
    <path d="M0,-12 L6,2 L20,4 L20,7 L6,6 L8,14 L12,15 L12,18 L4,16 L-4,16 L-12,18 L-12,15 L-8,14 L-6,6 L-20,7 L-20,4 L-6,2 Z" fill="#1a1a1a"/>
  </g>

  <!-- BOARDING TIME -->
  <text x="110" y="90" font-family="Arial, sans-serif" font-size="7.5" font-weight="700" fill="#cc1122" text-anchor="middle" letter-spacing="1">BOARDING TIME</text>
  <text x="110" y="103" font-family="Arial Black, Arial, sans-serif" font-size="14" font-weight="900" fill="#1a1a1a" text-anchor="middle">21:45</text>

  <!-- Gate -->
  <text x="50" y="90" font-family="Arial, sans-serif" font-size="7" fill="#888" letter-spacing="0.5">GATE</text>
  <text x="50" y="104" font-family="Arial Black, Arial, sans-serif" font-size="14" font-weight="900" fill="#1a1a1a">13A</text>

  <!-- Stub: right side -->
  <text x="228" y="60" font-family="Arial, sans-serif" font-size="6.5" fill="#666">JEAK BLACK</text>
  <text x="228" y="72" font-family="Arial, sans-serif" font-size="6.5" fill="#666">09 NOV 2018</text>
  <text x="228" y="84" font-family="Arial, sans-serif" font-size="6.5" fill="#666">SEAT 9A</text>
  <text x="228" y="96" font-family="Arial, sans-serif" font-size="6.5" fill="#666">GATE 13A</text>
</svg>,

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 240 100" width="240" height="100">
  <!-- Yellow background bar -->
  <rect x="0" y="10" width="240" height="55" fill="#FFCC00"/>
  <!-- DHL text - bold red italic -->
  <text x="20" y="56" font-family="Arial Black, Arial, sans-serif" font-size="52" font-weight="900" font-style="italic" fill="#D40511" dominant-baseline="auto">DHL</text>
  <!-- Speed lines left -->
  <rect x="0" y="68" width="240" height="4" fill="#FFCC00"/>
  <rect x="0" y="75" width="240" height="2.5" fill="#FFCC00"/>
  <rect x="0" y="80" width="240" height="1.5" fill="#FFCC00"/>
  <!-- EXPRESS text -->
  <text x="120" y="95" font-family="Arial, sans-serif" font-size="15" font-weight="700" font-style="italic" fill="#D40511" text-anchor="middle" letter-spacing="4">EXPRESS</text>
  <!-- Decorative red speed lines on the right inside yellow bar -->
  <rect x="185" y="22" width="55" height="4" fill="#D40511"/>
  <rect x="192" y="30" width="48" height="3" fill="#D40511"/>
  <rect x="198" y="37" width="42" height="2.5" fill="#D40511"/>
</svg>,

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200">
  <!-- SIM card shape -->
  <rect x="30" y="40" width="140" height="110" rx="14" ry="14" fill="#1a3ef0"/>
  <!-- SIM chip outline -->
  <rect x="48" y="62" width="54" height="44" rx="6" ry="6" fill="none" stroke="white" stroke-width="3.5"/>
  <!-- SIM chip gold contact -->
  <rect x="55" y="70" width="34" height="28" rx="3" ry="3" fill="#e8a020"/>
  <!-- Chip circuit lines -->
  <line x1="63" y1="70" x2="63" y2="98" stroke="#c07010" stroke-width="1.2"/>
  <line x1="71" y1="70" x2="71" y2="98" stroke="#c07010" stroke-width="1.2"/>
  <line x1="79" y1="70" x2="79" y2="98" stroke="#c07010" stroke-width="1.2"/>
  <line x1="55" y1="80" x2="89" y2="80" stroke="#c07010" stroke-width="1.2"/>
  <line x1="55" y1="88" x2="89" y2="88" stroke="#c07010" stroke-width="1.2"/>
  <!-- "blue" text -->
  <text x="112" y="100" font-family="Arial Rounded MT Bold, Arial, sans-serif" font-size="32" font-weight="900" fill="white" dominant-baseline="middle" text-anchor="middle">blue</text>
</svg>,









        
        
        
        
        
        
        
        
        
        
        ,].map(p => (
          <div class="partner-pill">{p}</div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
.page-hero {
  position: relative;
  min-height: 55vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg { position: absolute; inset: 0; }
.hero-img { width: 100%; height: 100%; object-fit: cover; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(26,58,107,0.82) 100%);
}
.hero-content {
  position: relative;
  z-index: 2;
  padding-top: 8rem;
  padding-bottom: 5rem;
  color: var(--white);
}
.breadcrumb {
  font-size: 0.82rem;
  color: rgba(255,255,255,0.6);
  margin-bottom: 1.2rem;
}
.breadcrumb a { color: rgba(255,255,255,0.6); }
.breadcrumb a:hover { color: var(--orange); }
.hero-content h1 {
  font-size: clamp(2rem, 4.5vw, 3.2rem);
  font-weight: 900;
  margin-bottom: 1rem;
}
.hero-content p { font-size: 1.1rem; color: rgba(255,255,255,0.8); }

/* INTRO BOX */
.services-intro { padding: 3.5rem 0; }
.intro-box {
  background: var(--blue-dark);
  border-radius: 20px;
  padding: 2.5rem 3rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}
.intro-box h2 {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 0.5rem;
}
.intro-box p { color: rgba(255,255,255,0.72); font-size: 0.92rem; max-width: 520px; }
.intro-ctas { display: flex; gap: 0.8rem; flex-shrink: 0; flex-wrap: wrap; }

/* SERVICE GROUPS */
.service-group { padding: 4rem 0; }
.bg-light { background: var(--gray-50); }
.group-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
}
.group-icon {
  width: 54px; height: 54px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.group-icon :global(svg) { width: 26px; height: 26px; }

.group-cards { display: grid; gap: 1.5rem; }
.group-cards.cols-3 { grid-template-columns: repeat(3, 1fr); }
.group-cards.cols-1 { grid-template-columns: 1fr; max-width: 720px; }

.detail-card {
  background: var(--white);
  border-radius: var(--radius);
  padding: 2rem;
  box-shadow: var(--shadow);
  border: 1px solid var(--gray-100);
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  transition: transform 0.25s, box-shadow 0.25s;
}
.detail-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); }
.dc-icon {
  width: 48px; height: 48px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
}
.dc-icon :global(svg) { width: 22px; height: 22px; }
.detail-card h3 {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--blue-dark);
}
.detail-card p {
  font-size: 0.88rem;
  color: var(--gray-600);
  line-height: 1.7;
  flex: 1;
}
.dc-actions {
  display: flex;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-top: 0.5rem;
}
.dc-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.82rem;
  font-weight: 600;
  padding: 0.5rem 1.1rem;
  border-radius: 50px;
  border: 1.5px solid currentColor;
  transition: all 0.2s;
}
.dc-btn:hover { opacity: 0.8; transform: translateY(-1px); }
.dc-btn-wa {
  color: #25D366;
}

/* PARTNERS */
.partners-section {
  background: var(--gray-50);
  padding: 3rem 0;
  border-top: 1px solid var(--gray-200);
}
.partners-label {
  text-align: center;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gray-400);
  margin-bottom: 1.5rem;
}
.partners-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}
.partner-pill {
  padding: 0.6rem 1.5rem;
  border-radius: 50px;
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--gray-600);
  transition: all 0.2s;
}
.partner-pill:hover { border-color: var(--blue-mid); color: var(--blue-mid); }

@media (max-width: 900px) {
  .group-cards.cols-3 { grid-template-columns: repeat(2, 1fr); }
  .intro-box { flex-direction: column; }
