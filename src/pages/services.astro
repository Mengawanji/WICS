---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const serviceGroups = [
  {
    id: "documentation",
    group: "Documentation & Administrative",
    color: "#1e4fa8",
    bgColor: "#e8efff",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    services: [
      { name: "Documentation Services", desc: "We handle all types of official documents including permits, certificates, attestations, apostilles, and administrative paperwork. Save time and let our experts manage the process from start to finish." }
    ]
  },
  {
    id: "satellite-tv",
    group: "Satellite TV Subscriptions",
    color: "#ea580c",
    bgColor: "#fff4ed",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="15" rx="2" ry="2"/><polyline points="17 2 12 7 7 2"/></svg>`,
    services: [
      { name: "CANAL+ Subscription", desc: "Subscribe or renew your CANAL+ package quickly and easily. We offer all CANAL+ plans with competitive rates. Same-day activation guaranteed." },
      { name: "DStv Subscription", desc: "All DStv packages available — Compact, Compact Plus, Premium and more. Fast subscription processing with instant activation." },
      { name: "StarTimes Subscription", desc: "Affordable StarTimes packages for all viewing needs. New subscriptions, renewals, and decoder sales available." }
    ]
  },
  {
    id: "travel",
    group: "Travel & Ticketing",
    color: "#0284c7",
    bgColor: "#e0f2fe",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>`,
    services: [
      { name: "Flight Ticket Sales", desc: "Book domestic and international flight tickets through our trusted travel partners. We help you find the best routes and prices for any destination." }
    ]
  },
  {
    id: "insurance",
    group: "Insurance",
    color: "#059669",
    bgColor: "#d1fae5",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    services: [
      { name: "AXA Motor Insurance", desc: "Official AXA Insurance partner for motor vehicle coverage. We offer third-party liability, comprehensive plans, and all standard AXA motor insurance products at competitive rates." }
    ]
  },
  {
    id: "courier",
    group: "Courier & Shipping",
    color: "#b45309",
    bgColor: "#fef3c7",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
    services: [
      { name: "DHL Express Services", desc: "Send documents and packages locally or internationally through DHL Express. We handle packing guidance, shipment booking, tracking setup, and pickup coordination." }
    ]
  },
  {
    id: "telecom",
    group: "Telecom Services",
    color: "#7c3aed",
    bgColor: "#ede9fe",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    services: [
      { name: "CAMTEL BLUE SIM – Sales", desc: "Purchase your CAMTEL BLUE SIM card with all standard plans for calls, SMS and mobile internet. Quick activation with identity verification support." },
      { name: "CAMTEL BLUE SIM – Recharge", desc: "Recharge your CAMTEL BLUE SIM with any amount. Fast, reliable, and no service fees. Available for all CAMTEL data and voice bundles." }
    ]
  }
];

const stats = [
  { value: "6+", label: "Service Categories" },
  { value: "10+", label: "Trusted Partners" },
  { value: "Same Day", label: "Activation" },
  { value: "100%", label: "Reliable" },
];
---

<Layout title="Our Services" description="WICS Agency offers documentation, CANAL+, DStv, StarTimes, flight tickets, AXA insurance, DHL, and CAMTEL services in Limbe, Cameroon.">
  <Navbar />

  <!-- HERO -->
  <section class="page-hero">
    <div class="hero-bg">
      <img
        src="https://res.cloudinary.com/drda6i3w6/image/upload/v1776367515/DSTV_okdx1q.jpg"
        alt="Business services"
        class="hero-img"
        loading="eager"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content">
      <div class="breadcrumb"><a href="/">Home</a> <span class="sep">/</span> <span>Services</span></div>
      <span class="hero-badge">What We Offer</span>
      <h1>Professional Services,<br/>Built Around You</h1>
      <p>Comprehensive solutions for individuals and businesses — handled with speed, accuracy, and care.</p>
      <div class="hero-actions">
        <a href="tel:+237699949035" class="btn btn-primary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
          Call Now
        </a>
        <a href="https://wa.me/237699949035" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <div class="stats-bar">
    <div class="container stats-inner">
      {stats.map(s => (
        <div class="stat-item">
          <strong>{s.value}</strong>
          <span>{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- QUICK NAV -->
  <nav class="quick-nav" aria-label="Service categories">
    <div class="container">
      <div class="qnav-inner">
        {serviceGroups.map(g => (
          <a href={`#${g.id}`} class="qnav-link" style={`--accent: ${g.color}`}>
            <span class="qnav-icon" set:html={g.icon}></span>
            <span>{g.group}</span>
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- SERVICE GROUPS -->
  <div class="services-wrapper">
    {serviceGroups.map((group, gi) => (
      <section id={group.id} class={`service-section ${gi % 2 === 1 ? 'alt-bg' : ''}`}>
        <div class="container">
          <div class="section-head">
            <div class="section-head-left">
              <div class="cat-icon" style={`background: ${group.bgColor}; color: ${group.color}`} set:html={group.icon}></div>
              <div>
                <p class="cat-label" style={`color: ${group.color}`}>{group.group}</p>
                <h2 class="cat-title">{group.services.length === 1 ? group.services[0].name : `${group.services.length} Services Available`}</h2>
              </div>
            </div>
            <div class="section-head-actions">
              <a href="tel:+237699949035" class="ghost-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
                Enquire
              </a>
            </div>
          </div>

          <div class={`cards-grid ${group.services.length === 1 ? 'single' : group.services.length === 2 ? 'two' : 'three'}`}>
            {group.services.map((s, si) => (
              <article class="svc-card" style={`--card-color: ${group.color}; --card-bg: ${group.bgColor}`}>
                <div class="card-top">
                  <div class="card-num">{String(si + 1).padStart(2, '0')}</div>
                  <div class="card-icon" set:html={group.icon}></div>
                </div>
                <h3>{s.name}</h3>
                <p>{s.desc}</p>
                <div class="card-footer">
                  <a href="tel:+237699949035" class="card-cta primary-cta">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
                    Call to Enquire
                  </a>
                  <a href="https://wa.me/237699949035" class="card-cta wa-cta" target="_blank" rel="noopener noreferrer">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    ))}
  </div>

  <!-- PARTNERS STRIP -->
  <section class="partners-section">
    <div class="container">
      <div class="partners-header">
        <p class="partners-eyebrow">Our Trusted Partners</p>
        <p class="partners-sub">We work with industry-leading brands to deliver the best service experience.</p>
      </div>
      <div class="partners-row">
        <div class="partner-pill">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 60" width="120" height="36">
            <rect x="0" y="0" width="200" height="60" rx="4" fill="#1a1a1a"/>
            <text x="100" y="42" font-family="Arial Black, sans-serif" font-size="36" font-weight="900" fill="white" text-anchor="middle">CANAL+</text>
          </svg>
        </div>
        <div class="partner-pill">
          <img src="/DStv.svg" alt="DStv" height="36" style="height:36px;width:auto;" />
        </div>
        <div class="partner-pill">
          <img src="/Start.png" alt="StarTimes" height="36" style="height:36px;width:auto;" />
        </div>
        <div class="partner-pill">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 60" width="120" height="44">
            <rect x="4" y="4" width="52" height="52" fill="#1a1f8c"/>
            <line x1="32" y1="6" x2="52" y2="54" stroke="#e8001c" stroke-width="5" stroke-linecap="round"/>
            <text x="30" y="44" font-family="Arial Black, sans-serif" font-size="22" font-weight="900" fill="white" text-anchor="middle">AXA</text>
            <text x="76" y="32" font-family="Georgia, serif" font-size="14" fill="#1a1f8c" dominant-baseline="middle">Insurance</text>
          </svg>
        </div>
        <div class="partner-pill">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 60" width="120" height="44">
            <rect x="0" y="8" width="160" height="38" fill="#FFCC00"/>
            <text x="14" y="38" font-family="Arial Black, sans-serif" font-size="38" font-weight="900" font-style="italic" fill="#D40511">DHL</text>
            <text x="100" y="30" font-family="Arial, sans-serif" font-size="11" font-weight="700" font-style="italic" fill="#D40511" text-anchor="middle" letter-spacing="2">EXPRESS</text>
          </svg>
        </div>
        <div class="partner-pill camtel-pill">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 60" width="90" height="44">
            <rect x="10" y="8" width="100" height="44" rx="8" fill="#1a3ef0"/>
            <rect x="18" y="16" width="36" height="28" rx="4" fill="none" stroke="white" stroke-width="2.5"/>
            <rect x="23" y="21" width="22" height="18" rx="2" fill="#e8a020"/>
            <text x="74" y="36" font-family="Arial Rounded MT Bold, Arial, sans-serif" font-size="20" font-weight="900" fill="white" dominant-baseline="middle" text-anchor="middle">blue</text>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="container">
      <div class="cta-box">
        <div class="cta-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
        </div>
        <div class="cta-text">
          <h2>Ready to Get Started?</h2>
          <p>Contact us today — we're available to assist you quickly and professionally.</p>
        </div>
        <div class="cta-btns">
          <a href="tel:+237699949035" class="btn btn-primary">Call Now</a>
          <a href="https://wa.me/237699949035" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">WhatsApp</a>
          <a href="/contact" class="btn btn-outline-dark">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
/* ── HERO ── */
.page-hero {
  position: relative;
  min-height: 60vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg { position: absolute; inset: 0; }
.hero-img { width: 100%; height: 100%; object-fit: cover; }
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(6,14,30,0.94) 0%, rgba(10,40,90,0.85) 100%);
}
.hero-content {
  position: relative;
  z-index: 2;
  padding-top: 9rem;
  padding-bottom: 5rem;
  color: var(--white);
}
.breadcrumb {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  margin-bottom: 1.4rem;
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.breadcrumb a { color: rgba(255,255,255,0.5); transition: color 0.2s; }
.breadcrumb a:hover { color: var(--orange); }
.breadcrumb .sep { color: rgba(255,255,255,0.3); }
.hero-badge {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--orange);
  background: rgba(249,115,22,0.15);
  border: 1px solid rgba(249,115,22,0.3);
  padding: 0.3rem 0.9rem;
  border-radius: 50px;
  margin-bottom: 1.2rem;
}
.hero-content h1 {
  font-size: clamp(2rem, 5vw, 3.4rem);
  font-weight: 900;
  line-height: 1.15;
  margin-bottom: 1rem;
  letter-spacing: -0.02em;
}
.hero-content p {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.72);
  max-width: 480px;
  margin-bottom: 2rem;
  line-height: 1.7;
}
.hero-actions { display: flex; gap: 0.8rem; flex-wrap: wrap; }

/* ── STATS BAR ── */
.stats-bar {
  background: var(--blue-dark);
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
.stats-inner {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 0;
  padding: 0;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 1.4rem 2.8rem;
  border-right: 1px solid rgba(255,255,255,0.07);
  min-width: 140px;
}
.stat-item:last-child { border-right: none; }
.stat-item strong {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--orange);
  letter-spacing: -0.02em;
}
.stat-item span {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.5);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-top: 0.15rem;
}

/* ── QUICK NAV ── */
.quick-nav {
  background: var(--white);
  border-bottom: 1px solid var(--gray-200);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 12px rgba(10,22,40,0.06);
}
.qnav-inner {
  display: flex;
  gap: 0;
  overflow-x: auto;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.qnav-inner::-webkit-scrollbar { display: none; }
.qnav-link {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  padding: 0.9rem 1.2rem;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--gray-600);
  white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: all 0.2s;
  flex-shrink: 0;
}
.qnav-link:hover {
  color: var(--accent, var(--blue-mid));
  border-bottom-color: var(--accent, var(--blue-mid));
  background: rgba(0,0,0,0.02);
}
.qnav-icon { display: flex; align-items: center; }
.qnav-icon :global(svg) { width: 14px; height: 14px; }

/* ── SERVICE SECTIONS ── */
.services-wrapper {}
.service-section { padding: 5rem 0; }
.alt-bg { background: var(--gray-50); }

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1.5rem;
  margin-bottom: 2.5rem;
  padding-bottom: 2rem;
  border-bottom: 1px solid var(--gray-200);
  flex-wrap: wrap;
}
.section-head-left {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}
.cat-icon {
  width: 58px;
  height: 58px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cat-icon :global(svg) { width: 26px; height: 26px; }
.cat-label {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.25rem;
}
.cat-title {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--blue-dark);
  letter-spacing: -0.02em;
}
