---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';

const services = [
  {
    title: "Documentation Services",
    description: "Professional handling of all your official documents, permits, certificates and administrative paperwork.",
    image: "https://res.cloudinary.com/drda6i3w6/image/upload/v1776367725/Documentation_e1mnd8.png"
  },
  {
    title: "CANAL+ & DStv Subscriptions",
    description: "Fast subscription activation and renewal for CANAL+, DStv and StarTimes – all in one convenient place.",
    image: "https://res.cloudinary.com/drda6i3w6/image/upload/v1776367515/DSTV_okdx1q.jpg"
  },
  {
    title: "Flight Ticket Sales",
    description: "Book domestic and international flights quickly and at competitive prices with our experienced team.",
    image: "https://res.cloudinary.com/drda6i3w6/image/upload/v1776367521/flight-ticket_nsrq9p.png"
  },
  {
    title: "Car Insurance",
    description: "Protect your vehicle with AXA insurance plans – comprehensive coverage at great rates.",
    image: "https://res.cloudinary.com/drda6i3w6/image/upload/v1776368358/car-insurance_u1ctio.jpg"
  },
  {
    title: "DHL Express Services",
    description: "Send and receive packages worldwide with DHL's trusted express shipping. Fast, trackable, reliable.",
    image: "https://res.cloudinary.com/drda6i3w6/image/upload/v1776367510/DHL_a2m6g5.jpg"
  },
  {
    title: "CAMTEL BLUE SIM",
    description: "Purchase and recharge your CAMTEL BLUE SIM for affordable national calls and internet data.",
    image: "https://res.cloudinary.com/drda6i3w6/image/upload/v1776368798/Camtell_svsnoi.jpg"
  },
];

const testimonials = [
  {
    name: "Emmanuel T.",
    role: "Business Owner, Limbe",
    text: "WICS Agency processed all my business documentation in record time. Professional, fast and affordable. Highly recommended!",
    stars: 5
  },
  {
    name: "Carine N.",
    role: "Teacher, Mokundange",
    text: "I renewed my DStv subscription and got my DHL parcel all in one visit. The team is always welcoming and efficient.",
    stars: 5
  },
  {
    name: "Daniel A.",
    role: "Contractor, Limbe",
    text: "Got my AXA motor insurance sorted quickly. WICS Agency made the process completely stress-free!",
    stars: 5
  }
];
---

<Layout title="Home – Fast & Reliable Services in Limbe">
  <Navbar />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <img
        src="https://res.cloudinary.com/drda6i3w6/image/upload/v1776370464/bgpic_xtp6q9.jpg"
        alt="Professional business building"
        class="hero-img"
        loading="eager"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-content fade-up">
      <div class="hero-badge">
        <span class="pulse"></span>
        Open Today · 8:00 AM – 6:00 PM
      </div>
      <h1>
        Your Trusted<br />
        <span class="hero-highlight">Business Agency</span><br />
        in Limbe
      </h1>
      <p class="hero-sub">
        Fast, reliable services you can count on. Documentation, insurance, subscriptions, shipping & more — all under one roof with 9+ years of excellence.
      </p>
      <div class="hero-actions">
        <a href="tel:+237699949035" class="btn btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
          Call Now
        </a>
        <a href="https://wa.me/237699949035" class="btn btn-outline" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
      <div class="hero-stats">
        <div class="stat"><span>9+</span><small>Years Experience</small></div>
        <div class="stat-divider"></div>
        <div class="stat"><span>8</span><small>Services Offered</small></div>
        <div class="stat-divider"></div>
        <div class="stat"><span>24/7</span><small>Customer Support</small></div>
      </div>
    </div>

    <div class="hero-scroll">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- INTRO BAND -->
  <section class="intro-band">
    <div class="container">
      <div class="band-items">
        <div class="band-item">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Fast Turnaround</span>
        </div>
        <div class="band-item">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Trusted & Reliable</span>
        </div>
        <div class="band-item">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>9+ Years of Experience</span>
        </div>
        <div class="band-item">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>24/7 Customer Support</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT TEASER -->
  <section class="about-teaser">
    <div class="container about-grid">
      <div class="about-image-wrap">
        <img
          src="https://res.cloudinary.com/drda6i3w6/image/upload/v1776365170/Euge_otsyjm.jpg"
          alt="Professional team at WICS Agency"
          class="about-img"
          loading="lazy"
        />
        <div class="about-badge">
          <strong>9+</strong>
          <span>Years of<br/>Excellence</span>
        </div>
      </div>
      <div class="about-text">
        <span class="section-label">Who We Are</span>
        <h2 class="section-title">Your One-Stop Agency in the Heart of Limbe</h2>
        <p class="section-subtitle">WICS Agency has been serving the Limbe community for over nine years with a wide range of professional services. Located conveniently beside the Port Authority Office in Mokundange, we are your go-to solution for documentation, subscriptions, insurance, shipping, and much more.</p>
        <ul class="about-list">
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Over 9 years of trusted service
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Friendly, knowledgeable staff
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Fast and efficient processing
          </li>
          <li>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Affordable and transparent pricing
          </li>
        </ul>
        <a href="/about" class="btn btn-blue">Learn More About Us</a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label">What We Offer</span>
        <h2 class="section-title">Our Core Services</h2>
        <p class="section-subtitle">Everything you need in one convenient location. Our experienced team is ready to assist you.</p>
      </div>
      <div class="services-grid">
        {services.map(s => (
          <ServiceCard title={s.title} description={s.description} image={s.image} />
        ))}
      </div>
      <div class="services-cta">
        <a href="/services" class="btn btn-blue">View All Services</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials">
    <div class="container">
      <div class="section-header">
        <span class="section-label">What People Say</span>
        <h2 class="section-title">Trusted by Our Community</h2>
      </div>
      <div class="testimonials-grid">
        {testimonials.map(t => (
          <div class="testimonial-card">
            <div class="stars">
              {Array.from({length: t.stars}).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="#f97316"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              ))}
            </div>
            <p class="testimonial-text">"{t.text}"</p>
            <div class="testimonial-author">
              <div class="author-avatar">{t.name.charAt(0)}</div>
              <div>
                <strong>{t.name}</strong>
                <small>{t.role}</small>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="cta-section">
    <div class="cta-bg">
      <img
        src="https://res.cloudinary.com/drda6i3w6/image/upload/v1776367512/Canal_bboo5v.jpg"
        alt="Business office"
        class="cta-img"
        loading="lazy"
      />
      <div class="cta-overlay"></div>
    </div>
    <div class="container cta-content">
      <h2>Ready to Get Started?</h2>
      <p>Visit us at Mokundange, Limbe or give us a call. We're open Monday to Saturday, 8 AM – 6 PM.</p>
      <div class="cta-actions">
        <a href="tel:+237699949035" class="btn btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.7A2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.16 6.16l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
          Call: 699 94 90 35
        </a>
        <a href="https://wa.me/237699949035" class="btn btn-whatsapp" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp Now
        </a>
        <a href="/contact" class="btn btn-outline">Get Directions</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
/* HERO */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
}
.hero-img {
  width: 100%; height: 100%;
  object-fit: cover;
  object-position: center;
}
.hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(10,22,40,0.92) 0%, rgba(26,58,107,0.78) 60%, rgba(30,79,168,0.5) 100%);
}
.hero-content {
  position: relative;
  z-index: 2;
  padding-top: 7rem;
  padding-bottom: 5rem;
  max-width: 680px;
  animation-delay: 0.1s;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 0.4rem 1rem;
  border-radius: 50px;
  margin-bottom: 1.5rem;
  backdrop-filter: blur(6px);
}
.pulse {
  width: 8px; height: 8px;
  background: #4ade80;
  border-radius: 50%;
  animation: pulse 2s infinite;
}
@keyframes pulse {
  0%,100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.4); }
}
.hero-content h1 {
  font-size: clamp(2.4rem, 5.5vw, 3.8rem);
  font-weight: 900;
  color: var(--white);
  line-height: 1.1;
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
}
.hero-highlight {
  color: var(--orange);
  position: relative;
}
.hero-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.82);
  line-height: 1.75;
  margin-bottom: 2.5rem;
  max-width: 560px;
}
.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}
.hero-stats {
  display: flex;
  align-items: center;
  gap: 2rem;
  flex-wrap: wrap;
}
.stat { text-align: center; }
.stat span {
  display: block;
  font-size: 2rem;
  font-weight: 800;
  color: var(--white);
  line-height: 1;
}
.stat small {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.65);
  font-weight: 500;
}
.stat-divider {
  width: 1px; height: 40px;
  background: rgba(255,255,255,0.2);
}
.hero-scroll {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  color: rgba(255,255,255,0.5);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.scroll-line {
  width: 1.5px;
  height: 36px;
  background: linear-gradient(to bottom, rgba(255,255,255,0.5), transparent);
  animation: scrollLine 1.8s ease infinite;
}
@keyframes scrollLine {
  0%,100% { opacity: 0.3; }
  50% { opacity: 1; }
}

/* INTRO BAND */
.intro-band {
  background: var(--blue-dark);
  padding: 1.75rem 0;
}
.band-items {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
}
.band-item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  font-size: 0.92rem;
}
.band-item svg { color: #4ade80; flex-shrink: 0; }

/* ABOUT TEASER */
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.about-image-wrap {
  position: relative;
}
.about-img {
  width: 100%;
  height: 480px;
  object-fit: cover;
  border-radius: 20px;
  box-shadow: var(--shadow-lg);
}
.about-badge {
  position: absolute;
  bottom: 2rem;
  right: -1.5rem;
  background: var(--orange);
  color: var(--white);
  padding: 1.2rem 1.8rem;
  border-radius: var(--radius);
  text-align: center;
  box-shadow: var(--shadow-lg);
}
.about-badge strong {
  display: block;
  font-size: 2.5rem;
  font-weight: 900;
  line-height: 1;
}
.about-badge span { font-size: 0.78rem; font-weight: 600; opacity: 0.9; }
.about-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  margin: 1.5rem 0 2rem;
}
.about-list li {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.92rem;
  font-weight: 500;
  color: var(--gray-600);
}

/* SERVICES */
.services-section { background: var(--gray-50); }
.section-header {
  text-align: center;
  margin-bottom: 3rem;
}
.section-header .section-subtitle {
  margin: 0 auto;
}
.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.services-cta {
  text-align: center;
  margin-top: 3rem;
}

/* TESTIMONIALS */
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-top: 2.5rem;
}
.testimonial-card {
  background: var(--white);
  border: 1px solid var(--gray-100);
  border-radius: var(--radius);
  padding: 2rem;
  box-shadow: var(--shadow);
  transition: transform 0.25s;
}
.testimonial-card:hover { transform: translateY(-4px); }
.stars { display: flex; gap: 3px; margin-bottom: 1rem; }
.testimonial-text {
  font-size: 0.92rem;
  color: var(--gray-600);
  line-height: 1.72;
  margin-bottom: 1.5rem;
  font-style: italic;
}
.testimonial-author {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.author-avatar {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: var(--blue-mid);
  color: var(--white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.testimonial-author strong {
  display: block;
  font-size: 0.9rem;
  color: var(--blue-dark);
}
.testimonial-author small {
  font-size: 0.78rem;
  color: var(--gray-400);
}

/* CTA SECTION */
.cta-section {
  position: relative;
  padding: 6rem 0;
  text-align: center;
  overflow: hidden;
}
.cta-bg {
  position: absolute; inset: 0;
}
.cta-img {
  width: 100%; height: 100%;
  object-fit: cover;
}
.cta-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(135deg, rgba(10,22,40,0.93) 0%, rgba(26,58,107,0.88) 100%);
}
.cta-content {
  position: relative;
  z-index: 2;
  color: var(--white);
}
.cta-content h2 {
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 800;
  margin-bottom: 1rem;
}
.cta-content p {
  font-size: 1.05rem;
  color: rgba(255,255,255,0.8);
  margin-bottom: 2.5rem;
  max-width: 520px;
  margin-left: auto; margin-right: auto;
}
.cta-actions {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

@media (max-width: 1000px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
  .testimonials-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
  .about-badge { right: 0; }
